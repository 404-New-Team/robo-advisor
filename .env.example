# Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# KRX 인증 (선택 — 없으면 yfinance .KS 폴백 사용)
# pykrx (회원 로그인 방식): https://krx.co.kr
KRX_ID=
KRX_PW=
# pykrx-openapi (인증키 방식): https://openapi.krx.co.kr
KRX_OPENAPI_KEY=

# ChromaDB (로컬 모드: 값 없이 두면 로컬 파일로 동작)
CHROMA_HOST=
CHROMA_PORT=8000

# Docker Compose 운영 배포
BACKEND_BIND=127.0.0.1
BACKEND_PORT=18080
FRONTEND_BIND=127.0.0.1
FRONTEND_PORT=18501
MYSQL_ROOT_PASSWORD=change-me-root-password

# Backend (Docker 네트워크 호스트명 사용)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=robo
MYSQL_PASSWORD=change-me-db-password
MYSQL_DB=roboadvisor

AI_SERVICE_URL=http://ai:8001
AI_TIMEOUT=30.0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
